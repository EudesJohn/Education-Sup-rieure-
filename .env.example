# ============================================================
# PEAN — Configuration (Supabase + Groq uniquement)
# ============================================================
# Copier vers .env pour le développement local.
# Aucune infrastructure locale requise — tout est en ligne.
# ============================================================

# === Mode développement ===
DEBUG=true

# === Supabase (base de données + stockage) ===
# ⚠️ Remplace par tes vraies clés Supabase
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre_cle_anon_ici
SUPABASE_SERVICE_KEY=votre_cle_service_ici  # Ne jamais exposer côté client

# === JWT — OBLIGATOIRE : générer une clé aléatoire ===
JWT_SECRET_KEY=CHANGER_CLE_JWT_openssl_rand_hex_32  # openssl rand -hex 32

# === CORS — domaines autorisés ===
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === Groq (IA Correction — seul fournisseur) ===
GROQ_API_KEY=votre_cle_groq_ici
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096

# === Exécution de code (étudiant) — DÉSACTIVÉ par défaut ===
ENABLE_CODE_EXECUTION=false
CODE_EXECUTION_MAX_TIME=10
CODE_EXECUTION_MAX_MEMORY_MB=256
